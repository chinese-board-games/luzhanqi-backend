{
    "extends": ["eslint:recommended", "prettier"],
    "rules": {
        "no-param-reassign": 0,
        "no-unused-vars": "off"
    },
    "parserOptions": {
        "ecmaVersion": "latest"
    },
    "env": {
        "es6": true,
        "node": true,
        "jest": true
    },
    "root": true
}
